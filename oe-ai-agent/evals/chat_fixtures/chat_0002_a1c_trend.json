{
  "label": "single-turn A1c trend question routes to lab trend tool",
  "turns": [
    {
      "label": "a1c trend",
      "user": "How has her A1c been trending?",
      "expectations": {
        "min_verified_facts": 1,
        "expected_fact_types_present": ["lab_result"],
        "expected_citations": ["obs-a1c-latest"],
        "expected_tools_called": ["get_lab_trend"],
        "narrative_must_contain": ["a1c", "7.2"],
        "facts_must_contain": ["7.2"]
      }
    }
  ],
  "fhir": {
